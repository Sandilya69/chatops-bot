# ══════════════════════════════════════════════════════
# ChatOps Deployment Bot — Environment Variables
# ══════════════════════════════════════════════════════
# Copy this file to config/local.env and fill in your values
# NEVER commit config/local.env to Git!
# ══════════════════════════════════════════════════════

# ── Server ──
PORT=3000

# ── Discord Bot ──
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here

# ── MongoDB ──
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/chatops

# ── GitHub ──
GITHUB_TOKEN=github_pat_your_personal_access_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_default_repo_name

# ── Security ──
ROOT_USER_ID=your_discord_user_id
DASHBOARD_SECRET=generate_a_random_string_here
GITHUB_WEBHOOK_SECRET=generate_a_random_string_here

# ══════════════════════════════════════════════════════
# HOW TO GENERATE SECURE SECRETS:
# 
# PowerShell:
#   [System.Guid]::NewGuid().ToString() + [System.Guid]::NewGuid().ToString()
#
# Node.js:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Linux:
#   openssl rand -hex 32
# ══════════════════════════════════════════════════════
